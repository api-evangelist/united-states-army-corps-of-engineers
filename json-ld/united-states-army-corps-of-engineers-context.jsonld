{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "dct": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "qudt": "http://qudt.org/schema/qudt/",
    "geo": "http://www.opengis.net/ont/geosparql#",
    "cwms": "https://cwms-data.usace.army.mil/vocab#",
    "sosa": "http://www.w3.org/ns/sosa/",
    "ssn": "http://www.w3.org/ns/ssn/",

    "USACE": {
      "@id": "schema:GovernmentOrganization",
      "@type": "@id"
    },
    "location": {
      "@id": "sosa:FeatureOfInterest",
      "@type": "@id"
    },
    "timeSeries": {
      "@id": "cwms:TimeSeries",
      "@type": "@id"
    },
    "observation": {
      "@id": "sosa:Observation",
      "@type": "@id"
    },
    "observedProperty": {
      "@id": "sosa:observedProperty",
      "@type": "@id"
    },
    "result": {
      "@id": "sosa:hasSimpleResult"
    },
    "resultTime": {
      "@id": "sosa:resultTime",
      "@type": "xsd:dateTime"
    },
    "phenomenonTime": {
      "@id": "sosa:phenomenonTime",
      "@type": "xsd:dateTime"
    },
    "unit": {
      "@id": "qudt:unit",
      "@type": "@id"
    },
    "datum": {
      "@id": "cwms:datum",
      "@type": "@id"
    },
    "office": {
      "@id": "cwms:office",
      "@type": "@id"
    },
    "qualityCode": {
      "@id": "cwms:qualityCode",
      "@type": "xsd:integer"
    },
    "interval": {
      "@id": "cwms:interval",
      "@type": "xsd:integer"
    },
    "basin": {
      "@id": "cwms:basin",
      "@type": "@id"
    },
    "reservoir": {
      "@id": "cwms:reservoir",
      "@type": "@id"
    },
    "project": {
      "@id": "cwms:project",
      "@type": "@id"
    },
    "rating": {
      "@id": "cwms:rating",
      "@type": "@id"
    },
    "forecast": {
      "@id": "cwms:forecast",
      "@type": "@id"
    },
    "level": {
      "@id": "cwms:level",
      "@type": "@id"
    },
    "stage": {
      "@id": "cwms:stage"
    },
    "flow": {
      "@id": "cwms:flow"
    },
    "elevation": {
      "@id": "cwms:elevation"
    },
    "latitude": {
      "@id": "schema:latitude",
      "@type": "xsd:double"
    },
    "longitude": {
      "@id": "schema:longitude",
      "@type": "xsd:double"
    },
    "name": "schema:name",
    "description": "schema:description",
    "url": "schema:url",
    "identifier": "schema:identifier"
  }
}
